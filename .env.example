# =============================================================================
# .env.example
# -----------------------------------------------------------------------------
# 운영/부하테스트 셸 스크립트(ops/*.sh, backend/run-backend.sh)가 source 하는
# 환경변수입니다. 실제 .env 는 .gitignore 처리되어 저장소에 없습니다.
#
#   cp .env.example .env   후 값을 채워 사용
#
# (Spring 백엔드 애플리케이션 설정은 application-local.yml 을 사용 — 별도 파일)
# =============================================================================

# ops/loadtest-db-backend.sh 의 MySQL 모니터링용 계정
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME

# (선택) HikariCP 커넥션 풀 튜닝 — 미설정 시 application.yml 기본값 사용
# DB_HIKARI_MAX_POOL_SIZE=60
# DB_HIKARI_MIN_IDLE=10
# DB_HIKARI_CONNECTION_TIMEOUT_MS=5000
# DB_HIKARI_VALIDATION_TIMEOUT_MS=2000
